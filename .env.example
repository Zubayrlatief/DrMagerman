# Canonical site URL (no trailing slash). Used for canonical links, Open Graph, and JSON-LD.
# Update public/sitemap.xml and public/robots.txt if your live domain differs.
VITE_SITE_URL=https://www.drmagerman.co.za

# Google Maps Embed API (free quota) — enables Google tiles on the Contact page.
# Create a key at https://console.cloud.google.com/ and enable "Maps Embed API".
# Leave empty to use OpenStreetMap in the same frame (address unchanged).
VITE_GOOGLE_MAPS_EMBED_KEY=
